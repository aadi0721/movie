# Frontend environment variables
# Copy this to .env and fill in your values

# Your TMDB API key
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# URL of your running Downloads API backend
# Local dev:
VITE_DOWNLOADS_API_URL=http://localhost:3001
# Production (after deploying api/ to Render/Railway):
# VITE_DOWNLOADS_API_URL=https://your-api.onrender.com
